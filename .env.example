# Copy this to .env and fill in your values
# Never commit .env to git

# ── Groq (required) ───────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ── Embedding (choose one backend) ────────────────────────

# OPTION A: Ollama with nomic-embed-text (RECOMMENDED — better quality)
# Requires: ollama pull nomic-embed-text && ollama serve
EMBEDDING_BACKEND=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# OPTION B: sentence-transformers (no Ollama needed, weaker quality)
# EMBEDDING_BACKEND=sentence-transformers
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Paths ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
DOCS_DIR=./docs

# ── RAG ───────────────────────────────────────────────────
RAG_TOP_K=5

# ── Session ───────────────────────────────────────────────
SESSION_TTL_MINUTES=60
MAX_SESSIONS=500

# ── App ───────────────────────────────────────────────────
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
