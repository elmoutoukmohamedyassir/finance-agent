
# ── Groq API ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192         
# ── App Settings ──────────────────────────────────────────
APP_ENV=development                 
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── RAG / ChromaDB ────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
